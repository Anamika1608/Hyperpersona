# Redis
REDIS_URL=redis://localhost:6379

# DynamoDB Local
DYNAMODB_ENDPOINT=http://localhost:8001
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# LLM backend (Phase 4) — pick one mode:
#   mock     deterministic stubs, no external calls (default)
#   real     AWS Bedrock (requires AWS creds + model access)
#   gemini   Google AI Studio (requires GEMINI_API_KEY, free tier)
BEDROCK_MODE=mock
BEDROCK_REGION=us-east-1
BEDROCK_TEXT_MODEL=anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# Gemini (only needed when BEDROCK_MODE=gemini)
# Get a free API key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001
# GEMINI_EMBED_DIM=1024

# OpenSearch (Phase 7+)
# OPENSEARCH_ENDPOINT=http://localhost:9200

# S3 traces (Phase 9+)
# S3_TRACES_BUCKET=hyperpersona-traces

# API auth (Phase 8+)
# API_KEY=test-key
